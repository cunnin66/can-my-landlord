# Google Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=

# Google Cloud Storage
GCS_BUCKET_NAME=can-my-landlord-leases
GCS_PROJECT_ID=your-gcp-project-id

# When running locally, point to your service account key file.
# On Cloud Run, this is not needed (uses default service account).
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
